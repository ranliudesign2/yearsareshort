{
  "manifest_version": 3,
  "name": "Years Are Short",
  "short_name": "Years Are Short",
  "version": "1.0.0",
  "description": "A mindful new tab experience combining daily intention-setting with mortality visualization.",
  "permissions": ["storage"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
